function searchBoots() {
    const query = document.getElementById('search').value;
    // Replace this URL with your backend or API URL
    const apiUrl = `https://api.example.com/search?query=${query}`;
    
    fetch(apiUrl)
        .then(response => response.json())
        .then(data => displayResults(data))
        .catch(error => console.error('Error fetching data:', error));
}

function displayResults(data) {
    const resultsDiv = document.getElementById('results');
    resultsDiv.innerHTML = ''; // Clear previous results

    data.forEach(boot => {
        const bootDiv = document.createElement('div');
        bootDiv.classList.add('boot');
        bootDiv.innerHTML = `
            <h2>${boot.name}</h2>
            <p>Price: ${boot.price}</p>
            <p>Available at: ${boot.store}</p>
            <a href="${boot.link}" target="_blank">Buy Now</a>
        `;
        resultsDiv.appendChild(bootDiv);
    });
}
function displayResults(data) {
    const resultsDiv = document.getElementById('results');
    resultsDiv.innerHTML = ''; // Clear previous results

    data.forEach(boot => {
        const bootDiv = document.createElement('div');
        bootDiv.classList.add('boot');
        bootDiv.innerHTML = `
            <h2>${boot.name}</h2>
            <img src="${boot.image}" alt="${boot.name}" style="max-width: 200px;">
            <p>Price: ${boot.price} (Available at: ${boot.store})</p>
            <h3>Price Comparison:</h3>
            <ul>
                ${Object.entries(boot.comparison).map(([store, price]) => `
                    <li>${store}: ${price}</li>
                `).join('')}
            </ul>
            <a href="#" target="_blank">Buy Now</a> 
        `;
        resultsDiv.appendChild(bootDiv);
    });
}
document.addEventListener('DOMContentLoaded', () => {
    const fetchBoots = async () => {
        try {
            const response = await fetch('/search');
            const boots = await response.json();
            displayBoots(boots);
        } catch (error) {
            console.error('Error fetching boots:', error);
        }
    };

    const displayBoots = (boots) => {
        const bootsContainer = document.getElementById('boots-container');
        bootsContainer.innerHTML = ''; // Clear previous entries
        boots.forEach(boot => {
            const bootElement = document.createElement('div');
            bootElement.classList.add('boot-item');
            bootElement.innerHTML = `<h3>${boot.brand} ${boot.model}</h3><p>Price: $${boot.price}</p>`;
            bootsContainer.appendChild(bootElement);
        });
    };

    fetchBoots();
});
